          },
          "event": [{"listen":"test","script":{"exec":["pm.test('Status 401',()=>pm.response.to.have.status(401));"]}}]
        },
        {
          "name": "Health Check",
          "request": {"method":"GET","url":"{{baseUrl}}/auth/health"},
          "event": [{"listen":"test","script":{"exec":["pm.test('API Running',()=>pm.response.to.have.status(200));"]}}]
        }
      ]
    },
