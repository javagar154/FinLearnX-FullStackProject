        {
          "name": "Register User",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/register",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\"name\":\"Arjun Sharma\",\"email\":\"arjun@test.com\",\"password\":\"test123\"}"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('Status 200',()=>pm.response.to.have.status(200));","const r=pm.response.json();if(r.data&&r.data.token){pm.collectionVariables.set('token',r.data.token);pm.test('Token saved',()=>pm.expect(r.data.token).to.be.a('string'));}"]}}]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\"email\":\"arjun@test.com\",\"password\":\"test123\"}"}
          },
          "event": [{"listen":"test","script":{"exec":["pm.test('Status 200',()=>pm.response.to.have.status(200));","const r=pm.response.json();if(r.data&&r.data.token){pm.collectionVariables.set('token',r.data.token);}","pm.test('JWT token present',()=>pm.expect(pm.collectionVariables.get('token')).to.not.be.empty);"]}}]
        },
        {
          "name": "Login - Invalid Credentials",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
